{
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && npx prisma db push && next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "env": {
    "NEXT_PUBLIC_APP_NAME": "Pathgrid Agency"
  }
}
