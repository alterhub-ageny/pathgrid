# Database (PostgreSQL - required)
# For local dev: install PostgreSQL or use Docker: docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 postgres
# For production: use a hosted provider like Neon (free at neon.tech) or Supabase
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pathgrid"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
SANITY_API_TOKEN=""

# Email (SendGrid or SMTP)
EMAIL_SERVER_HOST="smtp.sendgrid.net"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="apikey"
EMAIL_SERVER_PASSWORD="your-sendgrid-api-key"
EMAIL_FROM="noreply@pathgrid.agency"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Pathgrid Agency"
